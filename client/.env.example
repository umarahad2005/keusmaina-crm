# ─────────────────────────────────────────────────────────────────────────
#  FRONTEND env  (client/)  —  deploy target: VERCEL
#  Copy to client/.env for local dev. On Vercel, set this in the
#  dashboard → Settings → Environment Variables.
#  NOTE: Vite bakes this in at BUILD time, so after changing it you must
#  redeploy. Never commit the real .env (it's git-ignored).
# ─────────────────────────────────────────────────────────────────────────

# Where the backend API lives.
#   local → http://localhost:5000/api
#   prod  → your Render backend URL + /api,
#           e.g. https://keusmania-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api
