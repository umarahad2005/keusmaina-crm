# ─── Required ────────────────────────────────────────────────────────────
# MongoDB connection string. Use mongodb://localhost:27017/keusmania_crm for
# local dev, or your Atlas connection string for production (Vercel).
MONGO_URI=mongodb://localhost:27017/keusmania_crm

# JWT signing secret. Generate one with: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_here

# Local-dev only — Vercel ignores this and routes via /api/*
PORT=5000

# ─── Optional ────────────────────────────────────────────────────────────
# CORS origin for browser dev. Skip in production (same-origin on Vercel).
CLIENT_URL=http://localhost:5173

# ─── Cloudinary (required on Vercel — disk is read-only) ──────────────────
# Sign up at https://cloudinary.com (free tier: 25GB storage + 25GB/mo bandwidth).
# Find these on the Cloudinary dashboard → "Account Details".
# When ALL THREE are present, uploads automatically go to Cloudinary; when any
# is missing, the app falls back to writing files to ./uploads on local disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Subfolder inside the Cloudinary account where files land. Defaults to "keusmania".
CLOUDINARY_FOLDER=keusmania
