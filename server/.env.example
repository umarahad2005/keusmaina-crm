# ─────────────────────────────────────────────────────────────────────────
#  BACKEND env  (server/)  —  deploy target: RENDER
#  Copy to server/.env for local dev. On Render, set these in the
#  dashboard → Environment. Never commit the real .env (it's git-ignored).
# ─────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (use the mongodb+srv:// form).
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/keusmania_crm?retryWrites=true&w=majority

# JWT signing secret. Generate one with: openssl rand -base64 48
JWT_SECRET=your_long_random_secret_here

# CORS: the FRONTEND origin allowed to call this API.
#   local → http://localhost:5173
#   prod  → your Vercel URL, e.g. https://keusmaina-crm.vercel.app
CLIENT_URL=http://localhost:5173

# ── Cloudinary (file uploads) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=keusmania

# ── Local dev only ────────────────────────────────────────────────────────
# Port for local dev. Render sets PORT automatically — do NOT set it there.
PORT=5000

# ── Optional ──────────────────────────────────────────────────────────────
# Initial admin auto-created on first DB connect if none exists.
SEED_ADMIN_EMAIL=admin@keusmania.com
SEED_ADMIN_PASSWORD=change_me_after_first_login

# Keep-alive for sleep-prone hosts. On Render leave UNSET — it uses
# RENDER_EXTERNAL_URL automatically. Set only for other hosts:
# KEEPALIVE_URL=https://your-backend.onrender.com/api/health
